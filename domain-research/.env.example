# ---- The AI "brain" ----
# Pick which provider powers the agent. "claude" (default) or "openai".
LLM_PROVIDER=claude

# If LLM_PROVIDER=claude (Anthropic):
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-7
# Thinking depth / token spend: low | medium | high | xhigh | max
ANTHROPIC_EFFORT=high
# Adaptive thinking is on by default; set to "disabled" to cut latency/cost.
ANTHROPIC_THINKING=adaptive
# Caps the report length (also bounds thinking tokens).
ANTHROPIC_MAX_TOKENS=16000

# If LLM_PROVIDER=openai:
OPENAI_API_KEY=sk-...
# Any chat model with tool/function calling.
OPENAI_MODEL=gpt-4o

# ---- Supabase (Phase 1 data store) ----
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# The sb_secret_... key (privileged, server-side, bypasses RLS). Either name works.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ---- Master Domain List (SEPARATE Supabase project, internal domain registry) ----
# Read-only lookup: when a researched domain is in this list, its recorded owner
# is surfaced as an ownership signal. Server-side only (uses the secret key).
# The masterlist_lookup source only appears when BOTH of these are set.
MASTERLIST_SUPABASE_URL=https://YOUR-LIST-PROJECT.supabase.co
MASTERLIST_SUPABASE_SECRET_KEY=sb_secret_...

# ---- Naming Exercise universe (separate Supabase project) ----
# Used by the /naming tool to query name_universe (~6M domain candidates with
# pricing + quality scores). Distinct from the main app Supabase above.
SUPABASE_NAMING_URL=https://YOUR-NAMING-PROJECT.supabase.co
SUPABASE_NAMING_SERVICE_KEY=sb_secret_...
# Override the Haiku model used to parse free-form briefs into filter JSON.
ANTHROPIC_NAMING_MODEL=claude-haiku-4-5-20251001
# Optional: Google service-account JSON (single line) to enable sheet export
# from the Naming view. Not set → the "Export to Google Sheet" button returns
# 501 with a clear message; CSV export still works without it.
GOOGLE_SERVICE_ACCOUNT_JSON=

# ---- Inngest (job runtime) ----
# Easiest: install the Inngest integration on Vercel, which injects both of these.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ---- Email (Phase 3 notifications + password resets) ----
RESEND_API_KEY=
# Full From string. The domain must be verified in Resend (Resend → Domains
# → add + paste DNS records). When omitted, the code falls back to
# onboarding@resend.dev which only delivers to the Resend account holder.
EMAIL_FROM=
# Used in emailed report links. Default: https://research.snagged.com
APP_URL=

# ---- Access gate ----
# Multi-user auth (Phase 1): set ADMIN_EMAIL + ADMIN_PASSWORD and the first
# request after deploy will seed an admin row in domain_research_users.
# After that, log in with email + password; further users are added by the
# admin (Phase 2 UI; for now via SQL or /api/users when wired).
ADMIN_EMAIL=
ADMIN_PASSWORD=
# Secret used to sign auth cookies. Optional — falls back to APP_PASSWORD or a
# built-in default. Rotating this logs everyone out.
AUTH_SECRET=
# Legacy single-password gate. Still honored ONLY while domain_research_users
# is empty (so a deploy doesn't lock anyone out mid-migration); becomes inert
# once any user row exists.
APP_PASSWORD=

# ---- Rate limiting (Vercel KV) ----
# Create a KV store in the Vercel dashboard and link it to the project; Vercel
# injects KV_REST_API_URL / KV_REST_API_TOKEN automatically. With those set,
# /api/research is limited per IP. Without them (e.g. local dev) it fails open.
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_SEC=3600
# KV_REST_API_URL=        # set automatically by Vercel when KV is linked
# KV_REST_API_TOKEN=      # set automatically by Vercel when KV is linked

# ---- Free sources (no keys) ----
# rdap_whois, dns_lookup, wayback_history (now also crawls archived snapshots
# for prior-owner clues) and livesite_inspect (reads the live site / parking
# page) run with no configuration. Optional tuning:
# WAYBACK_CRAWL_MAX=8   # how many archived snapshots to fetch + mine for clues
# WAYBACK_CONTACT_MAX=6 # how many archived About/Contact sub-pages to crawl
# registration_cluster probes same-label siblings on other TLDs (free, RDAP):
# CLUSTER_TLDS=com,net,org,io,co,us,info,biz,me,app,ai,xyz,dev,tv,cc
# CLUSTER_MAX=14        # max sibling TLDs to check

# ---- RocketReach (owner contact intelligence) ----
# person SEARCH is free (no lookup credits); contact LOOKUP costs credits and is
# gated behind an explicit "go deeper" step. Auth is the Api-Key header.
ROCKETREACH_API_KEY=
# ROCKETREACH_URL_TEMPLATE=https://api.rocketreach.co/api/v2/person/search
# FullEnrich — WATERFALL contact lookup (premium; spends a credit). Runs many
# providers and returns the best work+personal emails (with deliverability) and
# phone for a named person. Gated behind "go deeper". Auth: Authorization: Bearer.
FULL_ENRICH_API_KEY=

# ---- Web & social search (premium) ----
# Powers web_search (Google results via Serper) for open-web / LinkedIn /
# Crunchbase / social / news lookups. Get a key at https://serper.dev
SERPER_API_KEY=

# ---- Trademark search (Signa.so, premium) ----
# Powers trademark_search (USPTO etc.) — a mark on the brand names the legal
# owner; even pending/abandoned apps name an applicant. Bearer-token auth.
SIGNA_TM_API_KEY=

# ---- Appraisal (Appraise.net, premium) ----
# Powers appraise_lookup (AI domain valuation). Two headers: X-API-Key +
# X-API-Secret. New appraisal = 3 credits, cached = 1.
APPRAISE_NET_KEY=
APPRAISE_NET_SECRET=

# ---- NameBio previous-sales history (premium, 1 credit/check) ----
# Powers namebio_sales — the "Previous sales" call-out in the Appraisal +
# Domain Owner reports. The API authenticates on the account email + key pair,
# so BOTH are required. Results are cached (kind 'nb') so repeat views are free.
NAMEBIO_API_KEY=
NAMEBIO_EMAIL=

# ---- Optional premium data sources ----
# Each source only appears to the AI when its keys are present.

# WhoisXML API (https://whoisxmlapi.com). Powers whoisxml_lookup (current WHOIS)
# plus reverse_whois / reverse_ns / reverse_ip (owner portfolio + shared infra).
# All reuse this one key.
WHOISXML_API_KEY=

# DomainIQ — just the key is needed; the module defaults to the verified
# domain_history endpoint with raw=1 (full history, not only changed records).
# Override the URL only if you want a different service/params ({domain} and
# {key} are substituted; domain is URL-encoded).
DOMAINIQ_API_KEY=
# DOMAINIQ_URL_TEMPLATE=https://www.domainiq.com/api?key={key}&service=domain_history&domain={domain}&output_mode=json&raw=1
# DomainIQ allowlists by IP. Vercel has no static egress IP, so route this source
# through a static-IP proxy (Fixie). Set FIXIE_URL to the proxy URL; only this
# source uses it.
# FIXIE_URL=http://fixie:PASSWORD@criterium.usefixie.com:80

# BigDomainData — just the key is needed; defaults to the historical WHOIS DB.
# Override the URL for current/fuzzy/keyword databases.
BIGDOMAINDATA_API_KEY=
# BIGDOMAINDATA_URL_TEMPLATE=https://api.bigdomaindata.com/?key={key}&database=historical&domain_name={domain}&page_size=100
